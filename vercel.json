{
  "headers": [
    {
      "source": "public/.well-known/assetlinks.json",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!manifest.json|icon|mandi|.well-known).*)",
      "destination": "/index.html"
    }
  ]
}